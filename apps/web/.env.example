# API base URL.
# Leave empty (recommended for LAN/production release bundles):
#   The app will automatically use the browser's hostname + VITE_API_PORT.
# Set explicitly for local dev only:
# VITE_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=

# API port used for auto-detection (only relevant when VITE_API_BASE_URL is empty)
VITE_API_PORT=3000

VITE_DEMO_PROJECT_ID=
