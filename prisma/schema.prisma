generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  pre
  production
  post
}

enum ContactCategory {
  crew
  cast
  other
}

model Project {
  id          String       @id @default(uuid()) @db.Uuid
  title       String
  description String?
  status      ProjectStatus
  startDate   DateTime?    @db.Date
  endDate     DateTime?    @db.Date
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  costCenters CostCenter[]
  positions   CostPosition[]
  expenses    Expense[]
  shootDays   ShootDay[]
  contacts    ProjectContact[]
  appointments ProjectAppointment[]
  contracts   ProjectContract[]
  timeEntries TimeEntry[]

  @@map("projects")
}

model CostCenter {
  id            String    @id @default(uuid()) @db.Uuid
  projectId     String    @db.Uuid
  name          String
  budget        Decimal   @default(0) @db.Decimal(12, 2)
  forecastCost  Decimal   @default(0) @db.Decimal(12, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expenses  Expense[]
  positions CostPosition[]
  budgets   BudgetScenario[]

  @@index([projectId])
  @@map("cost_centers")
}

model BudgetScenario {
  id           String    @id @default(uuid()) @db.Uuid
  costCenterId String    @db.Uuid
  name         String
  amount       Decimal   @db.Decimal(12, 2)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  costCenter   CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Cascade)

  @@index([costCenterId])
  @@map("budget_scenarios")
}

model CostPosition {
  id           String     @id @default(uuid()) @db.Uuid
  projectId    String     @db.Uuid
  costCenterId String     @db.Uuid
  parentId     String?    @db.Uuid
  name         String
  quantity     Decimal    @default(1) @db.Decimal(10, 2)
  unitRate     Decimal    @default(0) @db.Decimal(12, 2)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costCenter   CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Cascade)
  parent       CostPosition? @relation("PositionHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children     CostPosition[] @relation("PositionHierarchy")

  @@index([projectId])
  @@index([costCenterId])
  @@index([parentId])
  @@map("cost_positions")
}

model Expense {
  id           String     @id @default(uuid()) @db.Uuid
  projectId    String     @db.Uuid
  costCenterId String?    @db.Uuid
  amount       Decimal    @db.Decimal(12, 2)
  description  String?
  expenseDate  DateTime?  @db.Date
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([costCenterId])
  @@map("expenses")
}

model ShootDay {
  id        String    @id @default(uuid()) @db.Uuid
  projectId String    @db.Uuid
  date      DateTime  @db.Date
  location  String?
  locationOwner String?
  locationContactPerson String?
  notes     String?
  callTime  String?
  weather   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activities      ShootDayActivity[]
  scenes          Scene[]
  crewAssignments CrewAssignment[]
  castAssignments CastAssignment[]

  @@index([projectId])
  @@index([date])
  @@map("shoot_days")
}

model ShootDayActivity {
  id        String    @id @default(uuid()) @db.Uuid
  shootDayId String   @db.Uuid
  title     String
  time      String?
  crew      String?
  notes     String?
  transport String?
  equipment String?
  catering  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  shootDay  ShootDay  @relation(fields: [shootDayId], references: [id], onDelete: Cascade)

  @@index([shootDayId])
  @@map("shoot_day_activities")
}

model Scene {
  id                String    @id @default(uuid()) @db.Uuid
  shootDayId        String    @db.Uuid
  sceneNumber       String
  title             String
  synopsis          String?
  location          String?
  estimatedDuration Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  shootDay  ShootDay  @relation(fields: [shootDayId], references: [id], onDelete: Cascade)

  @@index([shootDayId])
  @@map("scenes")
}

model CrewAssignment {
  id         String    @id @default(uuid()) @db.Uuid
  shootDayId String    @db.Uuid
  name       String
  role       String?
  callTime   String?
  wrapTime   String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  shootDay   ShootDay  @relation(fields: [shootDayId], references: [id], onDelete: Cascade)

  @@index([shootDayId])
  @@map("crew_assignments")
}

model CastAssignment {
  id          String    @id @default(uuid()) @db.Uuid
  shootDayId  String    @db.Uuid
  name        String
  character   String?
  callTime    String?
  scenes      String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  shootDay    ShootDay  @relation(fields: [shootDayId], references: [id], onDelete: Cascade)

  @@index([shootDayId])
  @@map("cast_assignments")
}

model ProjectContact {
  id        String          @id @default(uuid()) @db.Uuid
  projectId String          @db.Uuid
  fullName  String
  category  ContactCategory @default(other)
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  appointments ProjectAppointment[]
  contracts    ProjectContract[]
  timeEntries  TimeEntry[]

  @@index([projectId])
  @@index([category])
  @@map("project_contacts")
}

model ProjectAppointment {
  id        String    @id @default(uuid()) @db.Uuid
  projectId String    @db.Uuid
  contactId String?   @db.Uuid
  title     String
  startAt   DateTime
  endAt     DateTime?
  location  String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact ProjectContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([contactId])
  @@index([startAt])
  @@map("project_appointments")
}

model ProjectContract {
  id             String    @id @default(uuid()) @db.Uuid
  projectId      String    @db.Uuid
  contactId      String?   @db.Uuid
  title          String
  contractType   String
  status         String
  signedAt       DateTime? @db.Date
  validFrom      DateTime? @db.Date
  validTo        DateTime? @db.Date
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact ProjectContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([contactId])
  @@index([status])
  @@map("project_contracts")
}

model TimeEntry {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @db.Uuid
  contactId    String?   @db.Uuid
  workDate     DateTime  @db.Date
  startTime    String?
  endTime      String?
  breakMinutes Int       @default(0)
  hours        Decimal   @db.Decimal(6, 2)
  activity     String
  approved     Boolean   @default(false)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contact ProjectContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([contactId])
  @@index([workDate])
  @@index([approved])
  @@map("time_entries")
}
